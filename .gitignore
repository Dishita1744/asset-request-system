# =============================================================================
# Frappe Bench - Root .gitignore
# =============================================================================

# ─── macOS ───────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
Icon?
._*
.Spotlight-V8
.Trashes

# ─── Python virtual environment ──────────────────────────────────────────────
env/
venv/
.venv/
*.pyc
*.pyo
*.pyd
__pycache__/
*.egg-info/
*.egg
.Python
pip-log.txt
pip-delete-this-directory.txt
.tox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.log
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
.ruff_cache/

# ─── Frappe bench internals ──────────────────────────────────────────────────
# Logs — keep the directory (bench requires it), ignore only the log files
logs/*.log
logs/*.error.log
!logs/.gitkeep

# Redis config files (machine-specific, auto-generated) — keep config/ dir itself
config/redis_cache.conf
config/redis_queue.conf
config/redis_cache.acl
config/redis_queue.acl
config/pids/
!config/.gitkeep

# Sites — site-specific secrets & uploads (only push site structure, not data)
sites/*/site_config.json
sites/*/indexes/
sites/*/locks/
sites/*/logs/
sites/*/private/
sites/*/public/files/
sites/*/.test_log
sites/*/touched_tables.json

# Assets (generated by `bench build`)
sites/assets/

# Migration / scheduler files
config/scheduler_process

# ─── Node / JS (top-level, in case) ──────────────────────────────────────────
node_modules/
dist/
dist-ssr/
*.local

# ─── Git / Editor ────────────────────────────────────────────────────────────
*.swp
*.swo
*~
.idea/
.vscode/
*.sublime-project
*.sublime-workspace
tags
TAGS

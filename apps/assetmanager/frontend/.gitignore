# =============================================================================
# Vue 3 / Vite Frontend - .gitignore
# =============================================================================

# ─── macOS ───────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble

# ─── Node ────────────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ─── Vite build output ───────────────────────────────────────────────────────
dist/
dist-ssr/
*.local

# ─── Environment files (contains secrets / machine-specific URLs) ─────────────
.env
.env.*
!.env.example

# ─── Auto-generated type declaration files (re-generated on dev start) ────────
auto-imports.d.ts
components.d.ts

# ─── Editor / IDE ────────────────────────────────────────────────────────────
*.swp
*.swo
*~
.idea/
.vscode/
*.sublime-project
*.sublime-workspace
